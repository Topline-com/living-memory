# Dreamcatcher Environment Variables
# Copy this file to .env and fill in your API key.

# Required: Anthropic API key for memory extraction (the one cloud touchpoint).
# This is ONLY used during the nightly extraction step (~$0.01-0.05/night).
# It is NOT used during inference, training, or when agents query the memory model.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key if using OpenAI as extraction provider
# Set DREAMCATCHER_PROVIDER=openai in your environment to use this instead.
# OPENAI_API_KEY=sk-...

# Optional: Override the extraction provider (default: anthropic)
# DREAMCATCHER_PROVIDER=anthropic
