# Dreamcatcher Environment Variables
# Copy this file to .env and fill in your API key.

# Required: OpenRouter API key for memory extraction (the one cloud touchpoint).
# This is ONLY used during the nightly extraction step (~$0.01-0.05/night).
# It is NOT used during inference, training, or when agents query the memory model.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: Anthropic API key if using Anthropic as extraction provider
# Set provider: "anthropic" in config.yaml or DREAMCATCHER_PROVIDER=anthropic.
# Requires: pip install anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key if using OpenAI as extraction provider
# Set provider: "openai" in config.yaml or DREAMCATCHER_PROVIDER=openai.
# OPENAI_API_KEY=sk-...

# Optional: Override the extraction provider (default: openrouter)
# DREAMCATCHER_PROVIDER=openrouter
